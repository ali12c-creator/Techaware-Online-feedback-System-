# TechAware Environment Variables Configuration Template
# Rename this file to .env and fill in your actual credentials

# Secret key for signing sessions and cookies (change to a random secure string in production)
SECRET_KEY=your-flask-secret-key-here

# Database connection URL (defaults to sqlite)
DATABASE_URL=sqlite:///techaware.db

# Google Gemini AI API key for generating recommendations and summaries
GEMINI_API_KEY=your-gemini-api-key-here

# SMTP credentials for sending automated emails (Gmail, Outlook, etc.)
MAIL_USERNAME=your-sender-email@gmail.com
MAIL_PASSWORD=your-email-app-password-here

# Teacher daily summary recipient fallback (optional)
TEACHER_EMAIL=recipient-teacher-email@gmail.com

# Base URL of the running application (used for generating links sent in emails)
BASE_URL=http://127.0.0.1:5000
