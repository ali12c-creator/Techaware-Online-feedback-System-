graph TB
    subgraph PL["🖥️ Presentation Layer (Jinja2 Templates + HTML/CSS/JS)"]
        direction LR
        H1["Home Page<br/>home.html"]
        H2["Student Login<br/>student_login.html"]
        H3["Admin Login<br/>admin.html"]
        H4["Feedback Form<br/>feedback.html"]
        H5["Teacher Dashboard<br/>dashboard.html"]
        H6["Student Dashboard<br/>student_dashboard.html"]
        H7["Admin Panel<br/>admin_manage.html"]
    end

    subgraph AL["⚙️ Application Layer (Flask 2.3.3 Backend)"]
        direction LR
        A1["Authentication<br/>Module<br/>(auth.py)"]
        A2["Feedback Processing<br/>Module<br/>(app.py)"]
        A3["Sentiment Analysis<br/>Engine<br/>(TextBlob NLP)"]
        A4["AI Suggestion<br/>Generator<br/>(Keyword Engine)"]
        A5["Email Notification<br/>Service<br/>(Gmail SMTP)"]
        A6["PDF Report<br/>Generator<br/>(ReportLab)"]
        A7["Academic Management<br/>Module<br/>(database.py)"]
    end

    subgraph DL["💾 Data Layer (SQLAlchemy ORM)"]
        direction LR
        D1[("SQLite<br/>techaware.db")]
        D2["Users"]
        D3["Students"]
        D4["Teachers"]
        D5["Feedbacks"]
        D6["Courses"]
        D7["Departments"]
        D8["Batches"]
        D9["Sections"]
        D10["Timetables"]
    end

    subgraph EXT["🌐 External Services"]
        E1["Gmail SMTP<br/>Server"]
        E2["Chart.js CDN<br/>(Visualization)"]
    end

    PL ==>|"HTTP Requests<br/>AJAX Calls"| AL
    AL ==>|"ORM Queries<br/>CRUD Operations"| DL
    A5 -->|"SMTP Protocol"| E1
    PL -.->|"CDN Script"| E2

