flowchart TD
    Start(("🟢 Start")) --> A["User Opens<br/>Application URL"]
    A --> B["Display Login Page<br/>(Student / Admin)"]
    B --> C["User Enters<br/>Email and Password"]
    C --> D["Click Login Button"]
    D --> E["System Queries<br/>Database for User"]
    E --> F{"User<br/>Found?"}
    F -->|"No"| G["❌ Display Error:<br/>Invalid Credentials"]
    G --> C
    F -->|"Yes"| H["Compare Password<br/>Hash (bcrypt)"]
    H --> I{"Password<br/>Valid?"}
    I -->|"No"| G
    I -->|"Yes"| J["✅ Create User Session<br/>(Flask Session)"]
    J --> K{"Check User<br/>Role"}
    K -->|"Student"| L["Redirect to<br/>Student Dashboard"]
    K -->|"Teacher"| M["Redirect to<br/>Teacher Dashboard"]
    K -->|"Admin"| N["Redirect to<br/>Admin Panel"]
    K -->|"Advisor"| O["Redirect to<br/>Advisor View"]
    L --> End(("🔴 End"))
    M --> End
    N --> End
    O --> End

    style Start fill:#4caf50,stroke:#2e7d32,stroke-width:3px,color:#fff
    style End fill:#f44336,stroke:#c62828,stroke-width:3px,color:#fff
